{
  "version": "1.0.0",
  "platform": "ios",
  "references": [],
  "category": "productivity",
  "design_system": {
    "color": {
      "mode": "auto",
      "light": {
        "primary": "#007AFF",
        "bg": "#F2F2F7",
        "label": "#000000",
        "secondary_label": "#3C3C43",
        "separator": "#C6C6C8"
      },
      "dark": {
        "primary": "#0A84FF",
        "bg": "#000000",
        "label": "#FFFFFF",
        "secondary_label": "#EBEBF5",
        "separator": "#38383A"
      },
      "semantic": "iOS system colors準拠。primary はアクションカラー"
    },
    "typography": {
      "family": "SF Pro",
      "scale": "iOS Dynamic Type",
      "weights": [400, 500, 600, 700]
    },
    "spacing": {
      "base": 4,
      "scale": [4, 8, 12, 16, 24, 32, 48]
    },
    "corner_radius": {
      "card": 12,
      "button": 10,
      "sheet": 16
    },
    "elevation": "subtle"
  },
  "motion": {
    "easing": "cubic-bezier(0.32, 0.72, 0, 1)",
    "duration": { "micro": 150, "standard": 250, "emphasized": 400 },
    "spring": { "stiffness": 300, "damping": 30 }
  },
  "sound": {
    "enabled": true,
    "ui_se_set": "subtle_haptic_complement",
    "loudness_target_lufs": -16
  },
  "copy": {
    "tone": "friendly_professional",
    "person": "second",
    "locale": ["ja", "en"]
  },
  "qc_thresholds": {
    "wcag": "AA",
    "min_tap_target_pt": 44,
    "max_bundle_mb": 50,
    "min_fps": 60
  }
}
