{
  "version": "1.0.0",
  "platform": "ios",
  "references": [],
  "category": "utility",
  "design_system": {
    "color": {
      "mode": "auto",
      "light": {
        "primary": "#5856D6",
        "bg": "#F2F2F7",
        "label": "#000000",
        "secondary_label": "#3C3C43",
        "separator": "#C6C6C8"
      },
      "dark": {
        "primary": "#5E5CE6",
        "bg": "#000000",
        "label": "#FFFFFF",
        "secondary_label": "#EBEBF5",
        "separator": "#38383A"
      },
      "semantic": "iOS system colors準拠。primary はニュートラルで汎用性の高いパープル"
    },
    "typography": {
      "family": "SF Pro",
      "scale": "iOS Dynamic Type",
      "weights": [400, 500, 600, 700]
    },
    "spacing": {
      "base": 4,
      "scale": [4, 8, 12, 16, 24, 32, 48]
    },
    "corner_radius": {
      "card": 10,
      "button": 8,
      "sheet": 16
    },
    "elevation": "flat"
  },
  "motion": {
    "easing": "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
    "duration": { "micro": 120, "standard": 220, "emphasized": 380 },
    "spring": { "stiffness": 320, "damping": 32 }
  },
  "sound": {
    "enabled": true,
    "ui_se_set": "minimal",
    "loudness_target_lufs": -16
  },
  "copy": {
    "tone": "formal",
    "person": "second",
    "locale": ["ja", "en"]
  },
  "qc_thresholds": {
    "wcag": "AA",
    "min_tap_target_pt": 44,
    "max_bundle_mb": 50,
    "min_fps": 60
  }
}
